<!doctype html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/news-logo.png" />
    <title>Contacto | 404 News</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="font-sans min-h-screen flex flex-col bg-gray-50">

    <header class="w-full p-4 bg-green-800 border-b border-green-900 shadow-md">
        <div class="flex flex-col gap-4 items-center lg:flex-row lg:justify-between max-w-7xl mx-auto">

            <a href="/index.html" class="cursor-pointer">
                <img class="w-32 lg:w-40 object-contain" src="/404news-logo.png" alt="404 News">
            </a>

            <nav class="text-white font-bold">
                <ul class="flex flex-col gap-3 items-center lg:flex-row lg:gap-6">
                    <li><a class="px-2 py-2 hover:border-b-2 hover:border-white transition-all" href="index.html">Inicio</a></li>
                    <li><a class="px-2 py-2 hover:border-b-2 hover:border-white transition-all" href="section.html">Lo Nuevo</a></li>
                    <li><a class="px-2 py-2 hover:border-b-2 hover:border-white transition-all" href="section.html">Tendencias</a></li>
                    <li><a class="px-2 py-2 hover:border-b-2 hover:border-white transition-all" href="section.html">IA</a></li>
                    <li><a class="px-2 py-2 hover:border-b-2 hover:border-white transition-all" href="section.html">PCs</a></li>
                    <li><a class="px-2 py-2 hover:border-b-2 hover:border-white transition-all" href="section.html">Moviles</a></li>
                    <li><a class="px-2 py-2 hover:border-b-2 hover:border-white transition-all" href="section.html">Otros</a></li>
                </ul>
            </nav>

            <button class="p-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-6 text-white">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                </svg>
            </button>
        </div>
    </header>

    <div class="flex-1 flex items-center justify-center p-6 py-12 lg:py-24">
        <div class="w-full max-w-5xl bg-white shadow-2xl flex flex-col md:flex-row overflow-hidden rounded-sm">
            
            <div class="flex-[1.5] p-8 lg:p-12">
                <h2 class="text-3xl font-normal text-gray-800 mb-8">Escríbenos</h2>
                
                <form action="#" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="relative">
                            <input type="text" placeholder="Nombre" class="w-full border-b border-gray-200 py-3 focus:outline-none focus:border-blue-500 transition-colors text-gray-600 placeholder-gray-400">
                        </div>
                        <div class="relative">
                            <input type="email" placeholder="Email" class="w-full border-b border-gray-200 py-3 focus:outline-none focus:border-blue-500 transition-colors text-gray-600 placeholder-gray-400">
                        </div>
                    </div>
                    
                    <div class="relative">
                        <input type="text" placeholder="Asunto" class="w-full border-b border-gray-200 py-3 focus:outline-none focus:border-blue-500 transition-colors text-gray-600 placeholder-gray-400">
                    </div>
                    
                    <div class="relative">
                        <textarea placeholder="Mensaje" rows="5" class="w-full border-b border-gray-200 py-3 focus:outline-none focus:border-blue-500 transition-colors text-gray-600 placeholder-gray-400 resize-none"></textarea>
                    </div>
                    
                    <div class="pt-4">
                        <button type="submit" class="bg-green-800 hover:bg-green-700 text-white px-8 py-3 rounded-md shadow-lg transition-all text-sm font-medium uppercase tracking-wider">
                            Enviar
                        </button>
                    </div>
                </form>
            </div>

            <div class="flex-1 bg-green-800 p-8 lg:p-12 text-white flex flex-col justify-center">
                <h3 class="text-3xl font-normal mb-10">Contactanos</h3>
                
                <div class="space-y-8">
                    <div class="flex items-start gap-4">
                        <div class="bg-green-400/30 p-3 rounded-full">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <div>
                            <p class="font-bold">Dirección:</p>
                            <p class="text-blue-50 font-light">La Vega, Rep. Dom., 41000</p>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="bg-green-400/30 p-3 rounded-full">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                        </div>
                        <div>
                            <p class="font-bold">Teléfono:</p>
                            <p class="text-blue-50 font-light">+1 829-552-4400</p>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="bg-green-400/30 p-3 rounded-full">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8m-18 0a2 2 0 012-2h14a2 2 0 012 2m-18 0v8a2 2 0 002 2h14a2 2 0 002-2V8" />
                            </svg>
                        </div>
                        <div>
                            <p class="font-bold">Email:</p>
                            <p class="text-blue-50 font-light">404news@gmail.com</p>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="bg-green-400/30 p-3 rounded-full">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <div>
                            <p class="font-bold">Servicios:</p>
                            <p class="text-blue-50 font-light">Generalmente respondemos dentro de las 24 horas.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

     <footer class="w-full">
        <div class="bg-green-800 border-b border-green-900">
            <div class="mx-auto lg:w-[calc(15rem*4+3rem)] p-4">
                <a href="/news.html" class="cursor-pointer">
                    <img class="w-44 max-h-24 object-contain" src="/404news-logo.png" alt="404 News">
                </a>
            </div>
        </div>

        <div class="bg-gray-800">
            <div
                class="flex flex-col md:flex-row md:items-start gap-10 md:gap-24 p-6 justify-center text-white font-bold">
                <div class="">
                    <ul class="space-y-2">
                        <li><a class="hover:underline" href="news.html">Inicio</a></li>
                        <li><a class="hover:underline" href="#">Lo Nuevo</a></li>
                        <li><a class="hover:underline" href="#">Tendencias</a></li>
                    </ul>
                </div>
                <div class="">
                    <h3 class="text-xl font-bold mb-2">Categorías</h3>
                    <ul class="space-y-2">
                        <li><a class="hover:underline" href="news.html">IA</a></li>
                        <li><a class="hover:underline" href="#">PCs</a></li>
                        <li><a class="hover:underline" href="#">Moviles</a></li>
                        <li><a class="hover:underline" href="#">Otros</a></li>
                    </ul>
                </div>
                <div class="">
                    <h3 class="text-xl font-bold mb-2">Información</h3>
                    <ul class="space-y-2">
                        <li><a class="hover:underline" href="news.html">Términos de uso</a></li>
                        <li><a class="hover:underline" href="#">Política de privacidad</a></li>
                        <li><a class="hover:underline" href="#">Contactanos</a></li>
                        <li><a class="hover:underline" href="#">Sobre Nosotros</a></li>
                    </ul>
                </div>
            </div>
            <p class="text-center text-white py-4">© 2026 404 NEWS</p>
    </footer>

</body>
</html>